{
  "name": "youmd",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "npm run dev:frontend & npm run dev:backend",
    "dev:frontend": "next dev --webpack -p 3100",
    "dev:frontend:turbo": "next dev --turbopack -p 3100",
    "dev:backend": "npx convex dev",
    "docs:generate": "node scripts/generate-docs-reference.mjs && npm run llms:generate",
    "docs:check": "node scripts/generate-docs-reference.mjs --check && npm run llms:check",
    "llms:generate": "node scripts/generate-llms-docs.mjs",
    "llms:check": "node scripts/generate-llms-docs.mjs --check",
    "llms:smoke": "node scripts/smoke-agent-docs.mjs",
    "agent-docs:syntax": "node --check scripts/generate-docs-reference.mjs && node --check scripts/generate-llms-docs.mjs && node --check scripts/smoke-agent-docs.mjs && node --check scripts/check-agent-doc-handoff.mjs",
    "agent-docs:handoff": "node scripts/check-agent-doc-handoff.mjs",
    "agent-docs:handoff:json": "node scripts/check-agent-doc-handoff.mjs --json",
    "agent-docs:lint": "npx eslint scripts/generate-docs-reference.mjs scripts/generate-llms-docs.mjs scripts/smoke-agent-docs.mjs scripts/check-agent-doc-handoff.mjs src/generated/docs-reference.ts src/generated/openapi.ts 'src/app/(app)/docs/docs-content.tsx'",
    "agent-docs:ci": "npm run docs:check && npm run agent-docs:syntax && npm run agent-docs:handoff && npm run agent-docs:lint",
    "profiles:portrait-contract": "node scripts/check-profile-portrait-contract.mjs",
    "profiles:portrait-audit": "node scripts/audit-public-profile-portraits.mjs",
    "profiles:portrait-audit:pages": "node scripts/audit-public-profile-portraits.mjs --check-pages --page-limit=all",
    "references:sync": "node scripts/reference-intelligence.mjs",
    "codex:chat-hygiene": "node scripts/codex-chat-hygiene.mjs",
    "prebuild": "npm run docs:generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "publish:cli": "./scripts/publish-cli-workflow.sh",
    "publish:cli:dry": "cd cli && npm pack --dry-run",
    "predev": "npx convex dev --until-success",
    "deploy:prod": "./scripts/convex-deploy.sh prod",
    "deploy:dev": "./scripts/convex-deploy.sh dev",
    "deploy:prod:remote": "./scripts/convex-deploy.sh --remote prod",
    "deploy:dev:remote": "./scripts/convex-deploy.sh --remote dev"
  },
  "dependencies": {
    "@vercel/og": "^0.11.1",
    "convex": "^1.33.1",
    "jpeg-js": "^0.4.4",
    "lucide-react": "^0.577.0",
    "motion": "^12.37.0",
    "next": "^16.2.7",
    "ogl": "^1.0.11",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
